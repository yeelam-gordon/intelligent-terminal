  </data>
  <data name="FreOverlay_InstallError_InstallerFailed" xml:space="preserve">
    <value>⚠ Инсталаторот за {0} пријави грешка (код {1}). Проверете го дневникот за детали или инсталирајте {0} рачно.</value>
