  </data>
  <data name="Diagnostics_ErrorDetectedTooltipFormat" xml:space="preserve">
    <value>U zbulua një gabim. Klikoni ose shtypni {0} që t'i kërkoni agjentit të IA të diagnostikojë dhe të sugjerojë një zgjidhje.</value>
