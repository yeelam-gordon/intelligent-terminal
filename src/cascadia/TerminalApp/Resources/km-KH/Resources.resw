  </data>
  <data name="FreOverlay_AutoDetectDescription.Text" xml:space="preserve">
    <value>ផ្តល់សិទ្ធិឱ្យ Intelligent Terminal ចូលប្រើសែលរបស់អ្នក និងរកឃើញកំហុសដោយស្វ័យប្រវត្តិ។</value>
