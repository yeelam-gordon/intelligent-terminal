  <!-- ═══ FRE Welcome Page ═══ -->
  <data name="FreOverlay_WelcomeTitle.Text" xml:space="preserve">
    <value>Բարի գալուստ Խելացի տերմինալ</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Կարգավորեք ձեր ներկառուց օգնականին՝ օգնելու ձեզ բացատրել սխալները, կազմել հրամաններ և ապաշստել առաջադրանքները հենց այնտեղ, որտեղ աշխատում եք։ </value>
  </data>
  <data name="FreOverlay_WelcomeSubtitleLink" xml:space="preserve">
    <value>Իմացեք ավելին Խելացի տերմինալ-ի մասին</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_Card1Title.Text" xml:space="preserve">
    <value>Մնացեք հոսքի մեջ ձեր ներկառուց AI գործակալով</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card1Description.Text" xml:space="preserve">
    <value>Ձեր գործակալը հետևում է, թե ինչ է կատարվում ձեր տերմինալում, և կարող է օգնել ձեզ հասկանալ և շտկել սխալները հենց դրանք հայտնվեն:</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card2Title.Text" xml:space="preserve">
    <value>Շարունակեք հենց այնտեղից, որտեղ կանգնեցիք</value>
  </data>
  <data name="FreOverlay_Card2Description.Text" xml:space="preserve">
    <value>Հետևեք ձեր ակտիվ և նախկին գործակալի նիստերը և վերադարձեք աշխատանքին վայրկյաններում։ Վերանայեք ընթացիկ առաջադրանքները կամ վերադարձեք նախկին աշխատանքին՝ առանց կորցնել ձեր տեղը:</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_NextButton.Content" xml:space="preserve">
    <value>Հաջորդ</value>
  </data>
