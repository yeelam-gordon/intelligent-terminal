  <!-- ═══ FRE Welcome Page ═══ -->
  <data name="FreOverlay_WelcomeTitle.Text" xml:space="preserve">
    <value>Aqlli terminal-ga xush kelibsiz</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Xatolarni tushuntirish, buyruqlar qoralash va tiqilib qolgan vazifalarni bevosita ish joyingizda hal qilishga yordam beradigan ichki yordamchini sozlang. </value>
  </data>
  <data name="FreOverlay_WelcomeSubtitleLink" xml:space="preserve">
    <value>Aqlli terminal haqida batafsil bilib oling</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_Card1Title.Text" xml:space="preserve">
    <value>Ichki AI agent bilan ish ritmingizni saqlang</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card1Description.Text" xml:space="preserve">
    <value>Agentingiz terminalda sodir bolayotgan voqealardan doimo xabardor va xatolar paydo bolganda ularni tushunish va tuzatishga yordam beradi.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card2Title.Text" xml:space="preserve">
    <value>Toxtagan joyingizdan davom eting</value>
  </data>
  <data name="FreOverlay_Card2Description.Text" xml:space="preserve">
    <value>Faol va avvalgi agent seanslarini kuzating va bir necha soniyada ishingizga qayting. Joriy ishlarni korib chiqing yoki oldingi ishlarga joyingizni yoqotmasdan qayta murojaat qiling.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_NextButton.Content" xml:space="preserve">
    <value>Keyingi</value>
  </data>
  <!-- ═══ FRE Settings Page ═══ -->
  <data name="FreOverlay_SettingsTitle.Text" xml:space="preserve">
    <value>Aqlli terminal-ga xush kelibsiz</value>
