  <!-- ═══ FRE Welcome Page ═══ -->
  <data name="FreOverlay_WelcomeTitle.Text" xml:space="preserve">
    <value>ઇન્ટેલિજન્ટ ટર્મિનલ માં આપનું સ્વાગત છે</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>ભૂલો સમજાવવા, આદેશો ઘડવા અને કાર્યોને અનબ્લોક કરવામાં મદદ કરવા માટે તમારા બિલ્ટ-ઇન સહાયકને સેટ અપ કરો, તમે જ્યાં કામ કરો છો ત્યાં જ. </value>
  </data>
  <data name="FreOverlay_WelcomeSubtitleLink" xml:space="preserve">
    <value>ઇન્ટેલિજન્ટ ટર્મિનલ વિશે વધુ જાણો</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_Card1Title.Text" xml:space="preserve">
    <value>તમારા બિલ્ટ-ઇન AI એજન્ટ સાથે પ્રવાહમાં રહો</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card1Description.Text" xml:space="preserve">
    <value>તમારો એજન્ટ તમારા ટર્મિનલમાં શું થઈ રહ્યું છે તેની જાણકારી રાખે છે અને ભૂલોને સમજવામાં અને ઠીક કરવામાં તમારી મદદ કરી શકે છે.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card2Title.Text" xml:space="preserve">
    <value>તમે જ્યાં છોડ્યું હતું ત્યાંથી જ શરૂ કરો</value>
  </data>
  <data name="FreOverlay_Card2Description.Text" xml:space="preserve">
    <value>તમારા સક્રિય અને ભૂતકાળના એજન્ટ સત્રોનો ટ્રૅક રાખો અને સેકન્ડોમાં તમારા કામ પર પાછા ફરો. પ્રગતિમાં શું છે તેની સમીક્ષા કરો અથવા તમારું સ્થાન ગુમાવ્યા વિના અગાઉના કામની ફરી મુલાકાત લો.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_NextButton.Content" xml:space="preserve">
    <value>આગલું</value>
  </data>
