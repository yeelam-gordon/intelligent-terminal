  </data>
  <data name="FreOverlay_AgentStatusInstalled" xml:space="preserve">
    <value> (air a stàladh)</value>
  </data>
  <data name="FreOverlay_PanePositionBottom" xml:space="preserve">
    <value>Bonn</value>
