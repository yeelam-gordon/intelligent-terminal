  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>Iestatiet iebūvēto palīgu, lai tas palīdzētu izskaidrot kļūdas, izveidot komandas un atrisināt uzdevumus tieši tur, kur strādājat. </value>
  </data>
  <data name="FreOverlay_WelcomeSubtitleLink" xml:space="preserve">
