  <!-- ═══ FRE Welcome Page ═══ -->
  <data name="FreOverlay_WelcomeTitle.Text" xml:space="preserve">
    <value>ಇಂಟೆಲಿಜೆಂಟ್ ಟರ್ಮಿನಲ್-ಗೆ ಸ್ವಾಗತ</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_WelcomeSubtitlePrefix" xml:space="preserve">
    <value>ದೋಷಗಳನ್ನು ವಿವರಿಸಲು, ಆಜ್ಞೆಗಳನ್ನು ಡ್ರಾಫ್ಟ್ ಮಾಡಲು ಮತ್ತು ಕಾರ್ಯಗಳನ್ನು ಅನ್‌ಬ್ಲಾಕ್ ಮಾಡಲು ಸಹಾಯ ಮಾಡಲು ನಿಮ್ಮ ಅಂತರ್ನಿರ್ಮಿತ ಸಹಾಯಕವನ್ನು ಹೊಂದಿಸಿ, ನೀವು ಕೆಲಸ ಮಾಡುವ ಸ್ಥಳದಲ್ಲಿಯೇ. </value>
  </data>
  <data name="FreOverlay_WelcomeSubtitleLink" xml:space="preserve">
    <value>ಇಂಟೆಲಿಜೆಂಟ್ ಟರ್ಮಿನಲ್ ಕುರಿತು ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_Card1Title.Text" xml:space="preserve">
    <value>ನಿಮ್ಮ ಅಂತರ್ನಿರ್ಮಿತ AI ಏಜೆಂಟ್‌ನೊಂದಿಗೆ ಪ್ರವಾಹದಲ್ಲಿ ಇರಿ</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card1Description.Text" xml:space="preserve">
    <value>ನಿಮ್ಮ ಏಜೆಂಟ್ ನಿಮ್ಮ ಟರ್ಮಿನಲ್‌ನಲ್ಲಿ ಏನು ನಡೆಯುತ್ತಿದೆ ಎಂಬುದರ ಬಗ್ಗೆ ಅರಿವು ಹೊಂದಿರುತ್ತದೆ ಮತ್ತು ದೋಷಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಲು ಮತ್ತು ಸರಿಪಡಿಸಲು ನಿಮಗೆ ಸಹಾಯ ಮಾಡಬಲ್ಲದು.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_Card2Title.Text" xml:space="preserve">
    <value>ನೀವು ಬಿಟ್ಟ ಸ್ಥಳದಿಂದಲೇ ಮುಂದುವರಿಸಿ</value>
  </data>
  <data name="FreOverlay_Card2Description.Text" xml:space="preserve">
    <value>ನಿಮ್ಮ ಸಕ್ರಿಯ ಮತ್ತು ಹಿಂದಿನ ಏಜೆಂಟ್ ಸೆಶನ್‌ಗಳನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಿ ಮತ್ತು ಸೆಕೆಂಡುಗಳಲ್ಲಿ ನಿಮ್ಮ ಕೆಲಸಕ್ಕೆ ಮರಳಿ. ಪ್ರಗತಿಯಲ್ಲಿ ಏನಿದೆ ಎಂಬುದನ್ನು ಪರಿಶೀಲಿಸಿ ಅಥವಾ ನಿಮ್ಮ ಸ್ಥಾನ ಕಳೆದುಕೊಳ್ಳದೆ ಹಿಂದಿನ ಕೆಲಸವನ್ನು ಮರುಭೇಟಿ ಮಾಡಿ.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_NextButton.Content" xml:space="preserve">
    <value>ಮುಂದೆ</value>
  </data>
  <!-- ═══ FRE Settings Page ═══ -->
  <data name="FreOverlay_SettingsTitle.Text" xml:space="preserve">
    <value>ಇಂಟೆಲಿಜೆಂಟ್ ಟರ್ಮಿನಲ್-ಗೆ ಸ್ವಾಗತ</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_SettingsSubtitlePrefix" xml:space="preserve">
    <value>ಈಗ ಏನನ್ನು ಹೊಂದಿಸಬೇಕೆಂದು ಆಯ್ಕೆಮಾಡಿ. ನೀವು ಇವುಗಳನ್ನು ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ಬದಲಾಯಿಸಬಹುಡು. </value>
  </data>
  <data name="FreOverlay_SettingsSubtitleLink" xml:space="preserve">
    <value>ಡೇಟಾವನ್ನು ಹೇಗೆ ಬಳಸಲಾಗುತ್ತದೆ ಎಂಬುದನ್ನು ತಿಳಿಯಿರಿ</value>
  </data>
  <data name="FreOverlay_AgentLabel.Text" xml:space="preserve">
    <value>ಏಜೆಂಟ್</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_AgentDescription.Text" xml:space="preserve">
    <value>ಏಜೆಂಟ್ ಪೇನ್‌ನಲ್ಲಿ ಬಳಸುವ ಮತ್ತು ACP ಬೆಂಬಲಿಸುವ ಏಜೆಂಟ್ ಅನ್ನು ಆಯ್ಕೆಮಾಡಿ.</value>
    <comment>{Locked="ACP"} In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_AgentInstallHint.Text" xml:space="preserve">
    <value>ಈ ಏಜೆಂಟ್‌ಗೆ Node.js ಮತ್ತು NPX ಅಗತ್ಯವಿದೆ, ಈಗಾಗಲೇ ಇಲ್ಲದಿದ್ದರೆ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಇನ್‌ಸ್ಟಾಲ್ ಆಗುತ್ತವೆ.</value>
    <comment>{Locked="Node.js","NPX"} In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_AutoErrorLabel.Text" xml:space="preserve">
    <value>ಸ್ವಯಂಚಾಲಿತ ದೋಷ ಸಲಹೆ</value>
  </data>
  <data name="FreOverlay_AutoErrorDescription.Text" xml:space="preserve">
    <value>ಪರಿಹಾರಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಸೂಚಿಸಲು ನಿಮ್ಮ ಏಜೆಂಟ್‌ಗೆ ದೋಷಗಳನ್ನು ಕಳುಹಿಸಲು Intelligent Terminal ಗೆ ಅನುಮತಿ ನೀಡಿ.</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name.</comment>
  </data>
  <data name="FreOverlay_SessionLabel.Text" xml:space="preserve">
    <value>ಸೆಶನ್ ನಿರ್ವಹಣೆ</value>
  </data>
  <data name="FreOverlay_SessionDescription.Text" xml:space="preserve">
    <value>ಇಂಟೆಲಿಜೆಂಟ್ ಟರ್ಮಿನಲ್ ಗೆ ನಿಮ್ಮ ಚಾಲನೆಯಲ್ಲಿರುವ ಅಥವಾ ಸಕ್ರಿಯ ಏಜೆಂಟ್‌ಗಳ ಸ್ಥಿತಿಯನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಲು ಅನುಮತಿ ನೀಡಿ.</value>
    <comment>{Locked=qps-ploc,qps-ploca,qps-plocm} "Intelligent Terminal" is the product name. In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_SessionHint.Text" xml:space="preserve">
    <value>ಇದನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುವುದರಿಂದ ನಿಮ್ಮ ಏಜೆಂಟ್‌ಗಳಾದ್ಯಂತ ಸೆಶನ್‌ಗಳನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಲು ಇಂಟಿಗ್ರೇಶನ್ hooks ಇನ್‌ಸ್ಟಾಲ್ ಆಗುತ್ತವೆ.</value>
    <comment>{Locked="hooks"} In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
  <data name="FreOverlay_PanePositionLabel.Text" xml:space="preserve">
    <value>ಪೇನ್ ಸ್ಥಾನ</value>
  </data>
  <data name="FreOverlay_PanePositionDescription.Text" xml:space="preserve">
    <value>ನಿಮ್ಮ ಟರ್ಮಿನಲ್‌ಗೆ ಸಂಬಂಧಿಸಿ ಏಜೆಂಟ್ ಪೇನ್ ಎಲ್ಲಿ ತೆರೆಯುತ್ತದೆ.</value>
    <comment>In this context, "agent" refers to an AI agent (e.g. Copilot, Claude, Gemini), not a human agent or representative.</comment>
  </data>
