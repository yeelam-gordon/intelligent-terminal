<UserControl x:Class="TerminalApp.FreOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!--  Backdrop: semi-transparent, proportional layout like CommandPalette  -->
    <Grid x:Name="RootGrid" Background="#80000000">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="6*" MaxWidth="782" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="6*" MaxHeight="556" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!--  Dialog: proportional sizing, Viewbox scales content uniformly  -->
        <Viewbox x:Name="DialogViewbox" Grid.Row="1" Grid.Column="1"
                 Stretch="Uniform"
                 StretchDirection="DownOnly">
            <Viewbox.RenderTransform>
                <TranslateTransform x:Name="DialogTranslate" X="0" Y="0" />
            </Viewbox.RenderTransform>
        <Border x:Name="DialogBorder"
                Width="782" Height="556"
                Background="#FF202020" CornerRadius="7"
                BorderBrush="#66757575" BorderThickness="1">
            <Grid>
                <!--  App surface overlay: bg rgba(255,255,255,0.05), rounded-[7px]  -->
                <Border Background="#0DFFFFFF" CornerRadius="7" />

                <!--  Title Bar: h-[32px], top-0, draggable  -->
                <Border x:Name="TitleBarDragArea" Height="32" VerticalAlignment="Top"
                        Background="Transparent"
                        PointerPressed="_OnTitleBarPointerPressed"
                        PointerMoved="_OnTitleBarPointerMoved"
                        PointerReleased="_OnTitleBarPointerReleased"
                        PointerCaptureLost="_OnTitleBarPointerCaptureLost">
                    <!--  Close button: 48×32, right-0  -->
                    <Button x:Name="CloseButton"
                            HorizontalAlignment="Right" Width="48" Height="32"
                            Background="Transparent" BorderBrush="Transparent" Padding="0"
                            Click="_OnCloseButtonClick"
                            FontFamily="Segoe Fluent Icons" FontSize="12"
                            Foreground="White" Content="&#xE8BB;" />
                </Border>

                <!--  Content: inset-[32px_2px_1px_0] → Margin="0,32,2,1"  -->
                <Grid Margin="0,32,2,1">

                    <!--  Sub-Head: absolute top-[8px] px-[24px]  -->
                    <TextBlock VerticalAlignment="Top"
                               Margin="24,8,24,0"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="20" FontWeight="SemiBold"
                               LineHeight="28" Foreground="White"
                               Text="{x:Bind FreTitle}" />

                    <!--  Section: absolute bottom-[12px] h-[458px] px-[12px]
                          flex gap-[4px] items-end  -->
                    <Grid VerticalAlignment="Bottom" Height="458"
                          Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <!--  Left-Column: shrink-0 w-[276px]  -->
                            <ColumnDefinition Width="Auto" />
                            <!--  gap-[4px]  -->
                            <ColumnDefinition Width="4" />
                            <!--  Right-Column: flex-[1_0_0]  -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  === Left-Column: exact structure from working version === -->
                        <Grid Grid.Column="0" Width="276">
                            <StackPanel x:Name="NavStack" Spacing="4" Padding="0,0,4,0">
                                <Grid x:Name="NavItem0" Height="84" Tapped="_OnNavItemTapped" Tag="0">
                                    <Border x:Name="NavBg0"
                                            Background="#0AFFFFFF" BorderBrush="#0AFFFFFF"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="6,3,6,3" />
                                    <Rectangle x:Name="NavSel0" Width="3" Height="32"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Fill="#FF60CDFF"
                                               RadiusX="1.5" RadiusY="1.5" />
                                    <StackPanel Margin="24,12,8,16" Spacing="4">
                                        <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   LineHeight="20" Foreground="White"
                                                   Text="{x:Bind Card1Title}" />
                                        <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                                   FontSize="12" LineHeight="16"
                                                   Foreground="#8AFFFFFF" Height="32"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{x:Bind Card1Description}" />
                                    </StackPanel>
                                </Grid>
                                <Grid x:Name="NavItem1" Height="84" Tapped="_OnNavItemTapped" Tag="1">
                                    <Border x:Name="NavBg1"
                                            Background="Transparent" BorderBrush="Transparent"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="6,3,6,3" />
                                    <Rectangle x:Name="NavSel1" Width="3" Height="32"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Fill="#FF60CDFF"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Visibility="Collapsed" />
                                    <StackPanel Margin="24,12,8,16" Spacing="4">
                                        <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   LineHeight="20" Foreground="White"
                                                   Text="{x:Bind Card2Title}" />
                                        <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                                   FontSize="12" LineHeight="16"
                                                   Foreground="#8AFFFFFF" Height="32"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{x:Bind Card2Description}" />
                                    </StackPanel>
                                </Grid>
                                <Grid x:Name="NavItem2" Height="84" Tapped="_OnNavItemTapped" Tag="2">
                                    <Border x:Name="NavBg2"
                                            Background="Transparent" BorderBrush="Transparent"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="6,3,6,3" />
                                    <Rectangle x:Name="NavSel2" Width="3" Height="32"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Fill="#FF60CDFF"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Visibility="Collapsed" />
                                    <StackPanel Margin="24,12,8,16" Spacing="4">
                                        <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   LineHeight="20" Foreground="White"
                                                   Text="{x:Bind Card3Title}" />
                                        <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                                   FontSize="12" LineHeight="16"
                                                   Foreground="#8AFFFFFF"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{x:Bind Card3Description}" />
                                    </StackPanel>
                                </Grid>
                                <Grid x:Name="NavItem3" Height="84" Tapped="_OnNavItemTapped" Tag="3">
                                    <Border x:Name="NavBg3"
                                            Background="Transparent" BorderBrush="Transparent"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="6,3,6,3" />
                                    <Rectangle x:Name="NavSel3" Width="3" Height="32"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               Fill="#FF60CDFF"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Visibility="Collapsed" />
                                    <StackPanel Margin="24,12,8,16" Spacing="4">
                                        <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   LineHeight="20" Foreground="White"
                                                   Text="{x:Bind Card4Title}" />
                                        <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                                   FontSize="12" LineHeight="16"
                                                   Foreground="#8AFFFFFF"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{x:Bind Card4Description}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!--  === Right-Column: flex-[1_0_0] flex-col h-full === -->
                        <Grid Grid.Column="2" VerticalAlignment="Stretch">
                            <!--  Card-Plate-Surface: bg rgba(58,58,58,0.3) rounded-[7px]  -->
                            <Border Background="#4D3A3A3A"
                                    BorderBrush="#0F000000" BorderThickness="1"
                                    CornerRadius="7" />

                            <!--  Card-Content-Wrapper: p-px z-[2]  -->
                            <Grid Margin="1">
                                <Grid.RowDefinitions>
                                    <!--  Image: aspect-[1600/900], shrink-0  -->
                                    <RowDefinition Height="*" />
                                    <!--  Context: h-[191px] shrink-0  -->
                                    <RowDefinition Height="191" />
                                </Grid.RowDefinitions>

                                <!--  Image-Wrapper: bg #0C0C0C rounded-tl-[5px] rounded-tr-[5px]  -->
                                <Border Grid.Row="0"
                                        Background="#FF0C0C0C"
                                        CornerRadius="5,5,0,0" />

                                <!--  Context: h-[191px] flex-col gap-[8px] pb-[4px]  -->
                                <Grid Grid.Row="1" Padding="0,0,0,4">
                                    <Grid.RowDefinitions>
                                        <!--  Text content: flex-[1_0_0] px-[24px] py-[20px] gap-[8px]  -->
                                        <RowDefinition Height="*" />
                                        <!--  Button Group: h-[43px] px-[12px] pt-[2px] pb-[12px]  -->
                                        <RowDefinition Height="43" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="24,20,24,0" Spacing="8">
                                        <!--  Title: 18px Semibold line-height 24  -->
                                        <TextBlock x:Name="DetailTitleText"
                                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   LineHeight="24" Foreground="White"
                                                   Text="{x:Bind DetailTitle}" />
                                        <!--  Description + link inline: 14px line-height 20, h-[60px]  -->
                                        <TextBlock x:Name="DetailDescriptionText"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="14" Foreground="White"
                                                   TextWrapping="Wrap" LineHeight="20" Height="60">
                                            <Run x:Name="DetailDescRun" Text="{x:Bind DetailDescription}" />
                                            <Run x:Name="DetailLinkSpacer" Text=" " />
                                            <Hyperlink x:Name="DetailLinkHyperlink"
                                                       NavigateUri="https://aka.ms/intelligent-terminal"
                                                       Foreground="#FF99EBFF">
                                                <Run x:Name="DetailLinkRun" Text="{x:Bind DetailLink}" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>

                                    <!--  Button Group: h-[43px] pt-[2px] pb-[12px] px-[12px]  -->
                                    <Grid Grid.Row="1" Margin="12,2,12,12">
                                        <!--  Start button: w-[120px] h-[32px] bg #60CDFF rounded-[5px]  -->
                                        <Button x:Name="StartButton"
                                                HorizontalAlignment="Right"
                                                Width="120" Height="32"
                                                Padding="11,5,11,5"
                                                Background="#FF60CDFF" Foreground="Black"
                                                FontFamily="Segoe UI Variable Text, Segoe UI"
                                                FontSize="14" CornerRadius="5"
                                                Click="_OnNextButtonClick"
                                                Content="{x:Bind NextButtonText}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        </Viewbox>
    </Grid>
</UserControl>
