    FRE (First Run Experience) two-step wizard.
    Full-screen content that replaces the terminal window during first run.
    Page 1: Welcome — feature highlights
    Page 2: Settings — agent selection + configuration

    Both pages share the same 3-zone layout (Top / Content / Bottom) so
    title, content, and button areas stay aligned across pages.
-->
<UserControl x:Class="TerminalApp.FreOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:TerminalApp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!--  Full-screen dark background  -->
    <Grid x:Name="RootGrid" Background="#FF1E1E1E">
        <Grid.RowDefinitions>
            <!--  Title bar space  -->
            <RowDefinition Height="32" />
            <!--  Content  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" />

        <!--  Shared 3-zone layout: Top (title) / Content / Bottom (button)
              Both pages are stacked in the same Grid so they share identical
              row proportions. Only one page is Visible at a time.  -->
        <Grid Grid.Row="1" Margin="40,8,40,16">
            <Grid.RowDefinitions>
                <!--  Top zone: title + subtitle  -->
                <RowDefinition Height="Auto" />
                <!--  Content zone: cards or settings form  -->
                <RowDefinition Height="*" />
                <!--  Bottom zone: button  -->
                <RowDefinition Height="48" />
            </Grid.RowDefinitions>

            <!--  ================================================================  -->
            <!--  PAGE 1: Welcome                                                  -->
            <!--  ================================================================  -->
            <Grid x:Name="WelcomePage" Grid.Row="0" Grid.RowSpan="3" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>

                <!--  Top: Title + Subtitle  -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,8,0,16" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="White" TextAlignment="Center"
                               LineHeight="28"
                               Text="Welcome to Intelligent Terminal" />
                    <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                               FontSize="13" Foreground="#B3FFFFFF"
                               TextAlignment="Center" TextWrapping="Wrap"
                               LineHeight="18" MaxWidth="480"
                               Margin="0,4,0,0">
                        <Run Text="Set up your built-in assistant to help you explain errors, draft commands, and unblock tasks right where you work. " />
                        <Hyperlink NavigateUri="https://aka.ms/intelligent-terminal"
                                   Foreground="#FF99EBFF">
                            <Run Text="Learn more about Intelligent Terminal" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!--  Content: Feature Cards  -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Card 1: Error Detection  -->
                    <Border Grid.Column="0" Background="#FF2D2D2D" CornerRadius="7">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="2*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF0C0C0C" CornerRadius="7,7,0,0"
                                    Margin="6,6,6,0">
                                <Image Source="ms-appx:///FREAssets/FRE_Asset1.png"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Bottom" />
                            </Border>
                            <StackPanel Grid.Row="1" Margin="16,14,16,16" Spacing="6">
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" LineHeight="18"
                                           Text="Stay in flow with your built-in AI agent" />
                                <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                           FontSize="12" Foreground="#8AFFFFFF"
                                           TextWrapping="Wrap" LineHeight="16"
                                           Text="Your agent stays aware of what's happening in your terminal and can help you understand and fix errors as they appear." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Card 2: Session Management  -->
                    <Border Grid.Column="2" Background="#FF2D2D2D" CornerRadius="7">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="2*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF0C0C0C" CornerRadius="7,7,0,0"
                                    Margin="6,6,6,0">
                                <Image Source="ms-appx:///FREAssets/FRE_Asset2.png"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Row="1" Margin="16,14,16,16" Spacing="6">
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" LineHeight="18"
                                           Text="Pick up right where you left off" />
                                <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                                           FontSize="12" Foreground="#8AFFFFFF"
                                           TextWrapping="Wrap" LineHeight="16"
                                           Text="Keep track of your active and past agent sessions and jump back into your work in seconds. Review what's in progress or revisit earlier work without losing your place." />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!--  Bottom: Next Button  -->
                <Grid Grid.Row="2">
                    <Button x:Name="NextButton"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="120" Height="32"
                            Background="#FF60CDFF" Foreground="Black"
                            FontFamily="Segoe UI Variable Text, Segoe UI"
                            FontSize="14" CornerRadius="5"
                            Click="_OnNextButtonClick"
                            Content="Next" />
                </Grid>
            </Grid>

            <!--  ================================================================  -->
            <!--  PAGE 2: Settings                                                 -->
            <!--  ================================================================  -->
            <Grid x:Name="SettingsPage" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>

                <!--  Top: Title + Subtitle  -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,8,0,16" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="White" TextAlignment="Center"
                               LineHeight="28"
                               Text="Welcome to Intelligent Terminal" />
                    <TextBlock FontFamily="Segoe UI Variable Small, Segoe UI"
                               FontSize="13" Foreground="#B3FFFFFF"
                               TextAlignment="Center" TextWrapping="Wrap"
                               LineHeight="18"
                               Margin="0,4,0,0">
                        <Run Text="Choose what to set up now. You can change these anytime in " />
                        <Hyperlink Foreground="#FF99EBFF">
                            <Run Text="Settings" />
                        </Hyperlink>
                        <Run Text="." />
                    </TextBlock>
                </StackPanel>

                <!--  Content: Settings Form  -->
                <ScrollViewer Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                        <!--  Agent  -->
                        <Border Background="#19FFFFFF" CornerRadius="4" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" Text="Agent" />
                                    <TextBlock FontSize="12" Foreground="#99FFFFFF"
                                               TextWrapping="Wrap"
                                               Text="Choose the agent CLI used in the agent pane. Any compatible ACP CLI will be detected." />
                                    <TextBlock x:Name="AgentInstallHint"
                                               FontSize="12" Foreground="#99FFFFFF"
                                               TextWrapping="Wrap" Visibility="Collapsed"
                                               Margin="0,4,0,0"
                                               Text="ℹ This agent requires Node.js and NPX, which will be installed automatically if not already present." />
                                </StackPanel>
                                <ComboBox x:Name="AgentComboBox" Grid.Column="1"
                                          MinWidth="220"
                                          VerticalAlignment="Center"
                                          SelectionChanged="_OnAgentSelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="local:FreAgentEntry">
                                            <TextBlock Text="{x:Bind DisplayLabel}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!--  Auto-error detection  -->
                        <Border Background="#19FFFFFF" CornerRadius="4" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" Text="Auto-error detection" />
                                    <TextBlock FontSize="12" Foreground="#99FFFFFF"
                                               TextWrapping="Wrap"
                                               Text="Give Intelligent Terminal permission to access your shell and auto detect errors." />
                                </StackPanel>
                                <ToggleSwitch x:Name="AutoErrorToggle" Grid.Column="1"
                                              IsOn="True" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" MinWidth="0"
                                              OnContent="On" OffContent="Off" />
                            </Grid>
                        </Border>

                        <!--  Session management  -->
                        <Border Background="#19FFFFFF" CornerRadius="4" Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" Text="Session management" />
                                    <TextBlock FontSize="12" Foreground="#99FFFFFF"
                                               TextWrapping="Wrap"
                                               Text="Give Intelligent Terminal permission to track the status of your running or active agents." />
                                </StackPanel>
                                <ToggleSwitch x:Name="SessionManagementToggle"
                                              Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                              IsOn="True" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" MinWidth="0"
                                              OnContent="On" OffContent="Off" />
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           FontSize="12" Foreground="#99FFFFFF"
                                           TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="ℹ Enabling this will install integration hooks to track sessions across your agent CLIs." />
                            </Grid>
                        </Border>

                        <!--  Pane position  -->
                        <Border Background="#19FFFFFF" CornerRadius="4" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="White" Text="Pane position" />
                                    <TextBlock FontSize="12" Foreground="#99FFFFFF"
                                               TextWrapping="Wrap"
                                               Text="Where the agent pane opens relative to your terminal." />
                                </StackPanel>
                                <ComboBox x:Name="PanePositionComboBox" Grid.Column="1"
                                          MinWidth="120"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!--  Bottom: Error text + Save Button  -->
                <Grid Grid.Row="2">
                    <TextBlock x:Name="ErrorText"
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Foreground="#FFFF6B6B" FontSize="13"
                               TextWrapping="Wrap" MaxWidth="400"
                               Visibility="Collapsed" />
                    <Button x:Name="SaveButton"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="120" Height="32"
                            Background="#FF60CDFF" Foreground="Black"
                            FontFamily="Segoe UI Variable Text, Segoe UI"
                            FontSize="14" CornerRadius="5"
                            Click="_OnSaveButtonClick"
                            Content="Save" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
