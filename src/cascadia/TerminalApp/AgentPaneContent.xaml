<UserControl x:Class="TerminalApp.AgentPaneContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:TerminalApp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ========= Agent bar (Figma: 36px tall, black, 1px top/bottom hairline) =========  -->
        <Border x:Name="AgentBarRoot"
                Grid.Row="0"
                Height="36"
                Background="#FF000000"
                BorderBrush="#26FFFFFF"
                BorderThickness="0,1,0,1">
            <Grid Padding="10,0,0,0">
                <!--  Left cluster: logo + label. History and other actions
                      live on the window-level bottom agent bar.  -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <!--  Agent logo. Source is a packaged white-filled SVG;
                          the URI is set from code-behind to ms-appx:///AgentIcons/<id>.svg.  -->
                    <Image x:Name="AgentLogo"
                           Width="14"
                           Height="14"
                           Stretch="Uniform" />
                    <TextBlock x:Name="AgentLabelText"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="12"
                               LineHeight="16"
                               Foreground="#FFFFFFFF"
                               Text="GitHub Copilot" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ========= Inner content (the wta TermControl, set in code-behind) =========  -->
        <ContentPresenter x:Name="InnerContent"
                          Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />
    </Grid>
</UserControl>
