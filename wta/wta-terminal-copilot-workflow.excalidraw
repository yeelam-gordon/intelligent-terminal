    {
      "type": "text",
      "id": "main_text",
      "x": 680,
      "y": 310,
      "width": 455,
      "height": 258,
      "text": "run_default_tui()\n  connect_to_wt_pipe()\n  discover_pane_identity()\n\nrun_acp_client()\n  initialize -> new_session -> prompt()\n  session_notification -> AgentMessageChunk / ToolCall / Plan\n  request_permission -> permission modal\n\nShellManager\n  create_terminal()\n  get_output()\n  wait_for_exit()\n  release() / kill()",
      "originalText": "run_default_tui()\n  connect_to_wt_pipe()\n  discover_pane_identity()\n\nrun_acp_client()\n  initialize -> new_session -> prompt()\n  session_notification -> AgentMessageChunk / ToolCall / Plan\n  request_permission -> permission modal\n\nShellManager\n  create_terminal()\n  get_output()\n  wait_for_exit()\n  release() / kill()",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
